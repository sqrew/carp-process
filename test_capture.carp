(load "process.carp")

(defn main []
  (let [p (Process.spawn "ls" &[@"-la" @"process.carp"])]
    (do
      (let [output (Process.read-all @(Process.T.stdout &p))]
        (do
          (IO.println &output)
          (let [exit-code (Process.wait &p)]
            (IO.println &(format "Process exited with code: %d" exit-code))))))))
