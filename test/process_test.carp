(load "Test.carp")
(use Test)
(load "process.carp")
(use Process)

(deftest process-test
  (let [p-res (Process.spawn "ls" &[@"process.carp"])
        s1 (match p-res
             (Result.Success p) (let [exit-code (Process.wait &p)]
                                  (assert-equal process-test 0 exit-code "Spawn 'ls' exits with 0"))
             (Result.Error err) (assert-true process-test false &(format "Failed to spawn 'ls': %s" &err)))

        cmd2 (Command.new "echo")
        cmd-with-args2 (Command.arg cmd2 "hello carp")
        output2 (Process.run &cmd-with-args2)
        s2 (assert-equal &s1 "hello carp\n" (Process.Output.stdout &output2) "Capture stdout from 'echo'")
        s3 (assert-equal &s2 0 @(Process.Output.exit-code &output2) "Run 'echo' exits with 0")

        cmd3 (Command.new "ls")
        cmd-with-args3 (Command.arg cmd3 "non_existent_file_xyz")
        output3 (Process.run &cmd-with-args3)
        s4 (assert-true &s3 (not (= "" (Process.Output.stderr &output3))) "Capture stderr from failed 'ls'")
        s5 (assert-true &s4 (not (= 0 @(Process.Output.exit-code &output3))) "Failed 'ls' exits with non-zero")

        p-res4 (Process.spawn "sh" &[@"-c" @"exit 42"])
        s6 (match p-res4
             (Result.Success p) (let [exit-code (Process.wait &p)]
                                  (assert-equal &s5 42 exit-code "Custom exit code via 'sh'"))
             (Result.Error err) (assert-true &s5 false &(format "Failed to spawn 'sh': %s" &err)))]
    s6))
